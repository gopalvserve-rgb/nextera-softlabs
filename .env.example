# ============================================================
# SmartCRM SaaS — environment variables
# ============================================================
# Copy to .env locally, or set on Railway, and fill real values.

# --- Postgres -----------------------------------------------
# Single Postgres cluster. The control DB is `smartcrm_control`,
# tenant DBs (tenant_<slug>) are auto-created on signup.
CONTROL_DATABASE_URL=postgres://user:pass@host:5432/smartcrm_control?sslmode=require

# --- App ----------------------------------------------------
PORT=3000
PUBLIC_BASE_URL=https://crm.smartcrmsolution.com
JWT_SECRET=change-me-to-a-long-random-string

# --- Cashfree (set via Admin → Settings, env is fallback) ---
CASHFREE_APP_ID=
CASHFREE_SECRET=
CASHFREE_MODE=PROD

# --- Email (set via Admin → Settings, env is fallback) -----
MAIL_PROVIDER=gmail
GMAIL_USER=
GMAIL_APP_PASSWORD=
SENDGRID_API_KEY=
MAIL_FROM=

# --- Bootstrap super-admin (used by control/seed.js) -------
SEED_ADMIN_EMAIL=admin@smartcrmsolution.com
SEED_ADMIN_PASSWORD=
