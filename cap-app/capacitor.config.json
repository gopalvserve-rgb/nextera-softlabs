{
  "appId": "app.leadcrm.mobile",
  "appName": "NextEra Softlabs",
  "webDir": "www",
  "server": {
    "url": "https://crm.nexterasoftlabs.com/app",
    "cleartext": false,
    "androidScheme": "https",
    "iosScheme": "https",
    "allowNavigation": [
      "crm.nexterasoftlabs.com",
      "*.nexterasoftlabs.com",
      "tel:*",
      "mailto:*",
      "whatsapp:*"
    ]
  },
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#0E1A14",
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "CallerId": {
      "enabled": true
    }
  },
  "ios": {
    "backgroundColor": "#0F172A",
    "contentInset": "always",
    "limitsNavigationsToAppBoundDomains": false,
    "scrollEnabled": true,
    "preferredContentMode": "mobile",
    "scheme": "App"
  }
}
